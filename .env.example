# === 수집(ingestion) 측 시크릿 — 복사해서 .env 로 저장 ===
# Supabase 프로젝트 Settings > API 에서 확인
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=         # service_role 키 (쓰기 권한, 절대 공개 금지)

# OpenAI gpt-image (인포그래픽/일러스트 생성) — Codex OAuth 와 별개의 API 키
OPENAI_API_KEY=sk-...

# Supabase Storage 버킷 이름
SUPABASE_BUCKET_ATTACHMENTS=attachments
SUPABASE_BUCKET_IMAGES=images
