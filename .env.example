# KRC World Market — 환경변수 예시
# 이 파일을 복사해서 .env 로 저장 후 실제 값을 입력하세요.
# .env 파일은 절대 git에 커밋하지 마세요.

# Flask 환경 (development | production)
FLASK_ENV=development

# 관리자 인증 키 — 반드시 변경하세요
ADMIN_KEY=change-this-to-a-strong-random-key

# 데이터베이스 (미설정 시 SQLite 사용)
# PostgreSQL 사용 시 아래 주석 해제 및 실제 값 입력
# DATABASE_URL=postgresql://user:password@host:5432/krc_worldmarket

# 수집기 API 키
# UNGM developer API 키 (https://developer.ungm.org/)
UNGM_API_KEY=

# KOICA data.go.kr 서비스 키 (없으면 HTML 스크래핑 fallback)
KOICA_API_KEY=

# CORS 허용 오리진 (운영 시 실제 도메인으로 변경)
# CORS_ORIGINS=https://your-domain.com

# 서버 포트
PORT=5001
