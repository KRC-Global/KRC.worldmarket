# Supabase PostgreSQL 연결 (Dashboard > Settings > Database > Connection string)
# Session Mode Pooler URL 권장
DATABASE_URL=postgresql://postgres.pvmhqxcjcxhltuholhlp:[YOUR-DB-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ── 수집기 API 키 ──────────────────────────────────────────────────────────────
UNGM_API_KEY=
KOICA_API_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
# 프로덕션 배포 시 실제 도메인으로 변경
CORS_ORIGINS=*
