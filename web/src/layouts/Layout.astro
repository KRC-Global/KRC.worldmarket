---
interface Props { title?: string }
const { title = "MDB 농업 발주공고" } = Astro.props;
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <title>{title}</title>
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <style is:global>
      /* Pretendard — 한글 우선 고품질 산세리프 (variable dynamic-subset, font-display: swap 내장) */
      @import url("https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.css");

      :root {
        color-scheme: dark;

        /* Slack 다크 표면 */
        --bg: #16181c;
        --bg-elevated: #1b1d22;
        --surface: #1f2125;
        --surface-2: #25272c;
        --surface-hover: #2a2c31;
        --line: #34363b;
        --line-soft: #2a2c31;

        /* 텍스트 */
        --fg: #e8e9eb;
        --muted: #9a9da3;
        --faint: #6e7178;

        /* Slack 브랜드 — 어버진 (단일 액센트) */
        --aubergine: #4a154b;
        --aubergine-600: #611f69;
        --aubergine-700: #3a1039;
        --accent: #cda4d6;        /* 다크 배경용으로 끌어올린 어버진: 링크/액티브 텍스트 (WCAG AA pass) */
        --accent-strong: #b07fca;
        --on-accent: #ffffff;

        /* Slack 카테고리 팔레트 — 차트/배지 데이터 전용 */
        --slack-blue: #36c5f0;
        --slack-green: #2eb67d;
        --slack-red: #e01e5a;
        --slack-yellow: #ecb22e;

        /* 형상 시스템 — 카드 12 / 입력·버튼 10 / 배지 pill */
        --radius: 12px;
        --radius-sm: 10px;
        --shadow: 0 1px 2px rgb(0 0 0 / .35), 0 10px 30px rgb(0 0 0 / .25);
        --shadow-soft: 0 1px 2px rgb(0 0 0 / .3);
        --ring: 0 0 0 3px rgb(74 21 75 / .55);

        --maxw: 1200px;
      }

      * { box-sizing: border-box; }

      html { scroll-behavior: smooth; }

      body {
        margin: 0;
        min-height: 100dvh;
        background:
          radial-gradient(1100px 480px at 50% -260px, rgb(74 21 75 / .28), transparent 70%),
          var(--bg);
        background-attachment: fixed;
        color: var(--fg);
        font-family: "Pretendard Variable", Pretendard, -apple-system, "Apple SD Gothic Neo",
          system-ui, "Segoe UI", Roboto, sans-serif;
        font-feature-settings: "tnum" 1;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        line-height: 1.55;
      }

      a { color: inherit; text-decoration: none; }
      a.link { color: var(--accent); }
      a.link:hover { color: #fff; }

      h1 { font-size: clamp(1.5rem, 1.1rem + 1.6vw, 2.05rem); font-weight: 750; letter-spacing: -.02em; line-height: 1.18; margin: 0 0 .25em; }
      h2 { font-size: 1.25rem; font-weight: 700; letter-spacing: -.01em; margin: 0 0 .4em; }
      h3 { font-size: .98rem; font-weight: 650; letter-spacing: -.01em; margin: 0 0 .7em; color: var(--fg); }
      p { margin: .4em 0; }

      /* ── 헤더 ── */
      header.site {
        position: sticky; top: 0; z-index: 50;
        height: 64px;
        display: flex; align-items: center; gap: 28px;
        padding: 0 24px;
        background: rgb(22 24 28 / .82);
        backdrop-filter: saturate(160%) blur(12px);
        -webkit-backdrop-filter: saturate(160%) blur(12px);
        border-bottom: 1px solid var(--line-soft);
      }
      .brand { display: inline-flex; align-items: center; gap: 11px; font-weight: 750; letter-spacing: -.02em; font-size: 1.02rem; }
      .brand .mark {
        width: 30px; height: 30px; border-radius: 9px; flex: none;
        background: linear-gradient(150deg, var(--aubergine-600), var(--aubergine));
        box-shadow: inset 0 1px 0 rgb(255 255 255 / .14), 0 2px 8px rgb(74 21 75 / .5);
        position: relative;
      }
      /* 단순 기하 마크 — 새싹(원형 + 줄기) */
      .brand .mark::before { content: ""; position: absolute; inset: 0; margin: auto; width: 7px; height: 7px; border-radius: 50%; background: #fff; top: 7px; }
      .brand .mark::after { content: ""; position: absolute; left: 50%; transform: translateX(-50%); bottom: 6px; width: 2.5px; height: 9px; border-radius: 2px; background: rgb(255 255 255 / .85); }
      .brand small { color: var(--muted); font-weight: 500; font-size: .72rem; letter-spacing: .01em; }

      nav.site { display: flex; gap: 4px; align-items: center; }
      nav.site a {
        color: var(--muted); font-size: .9rem; font-weight: 550;
        padding: 7px 13px; border-radius: 8px;
        transition: color .15s ease, background .15s ease;
      }
      nav.site a:hover { color: var(--fg); background: var(--surface-2); }
      nav.site a[aria-current="page"] { color: #fff; background: var(--aubergine); }

      main { max-width: var(--maxw); margin: 0 auto; padding: 32px 24px 72px; }

      /* ── 카드 / 그리드 ── */
      .card {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 18px;
        box-shadow: var(--shadow-soft);
      }
      .card.pad-lg { padding: 22px; }
      .grid { display: grid; gap: 16px; }

      /* 통계 카드 */
      .stat {
        position: relative; overflow: hidden;
        background: linear-gradient(180deg, var(--surface-2), var(--surface));
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 18px 20px;
        transition: border-color .18s ease, transform .18s ease;
      }
      .stat::before { content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: var(--aubergine); opacity: .9; }
      .stat:hover { border-color: var(--accent-strong); transform: translateY(-2px); }
      .stat .k { color: var(--muted); font-size: .82rem; font-weight: 550; }
      .stat .v { font-size: 2rem; font-weight: 760; letter-spacing: -.02em; font-variant-numeric: tabular-nums; margin-top: 2px; }

      /* 배지 (기관/카테고리) */
      .badge {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 3px 10px; border-radius: 999px;
        font-size: .76rem; font-weight: 600; letter-spacing: .01em;
        background: rgb(74 21 75 / .3); color: var(--accent);
        border: 1px solid rgb(176 127 202 / .3);
        white-space: nowrap;
      }
      .badge .dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }

      /* 폼 컨트롤 */
      .field { background: var(--bg-elevated); color: var(--fg); border: 1px solid var(--line); border-radius: var(--radius-sm); padding: 9px 13px; font: inherit; font-size: .9rem; transition: border-color .15s ease, box-shadow .15s ease; }
      .field::placeholder { color: var(--faint); }
      .field:focus { outline: none; border-color: var(--accent-strong); box-shadow: var(--ring); }

      /* 버튼 */
      .btn { display: inline-flex; align-items: center; gap: 7px; padding: 9px 16px; border-radius: var(--radius-sm); font: inherit; font-size: .9rem; font-weight: 600; cursor: pointer; border: 1px solid transparent; transition: transform .12s ease, background .15s ease, border-color .15s ease; }
      .btn-primary { background: linear-gradient(150deg, var(--aubergine-600), var(--aubergine)); color: var(--on-accent); box-shadow: 0 2px 10px rgb(74 21 75 / .45); }
      .btn-primary:hover { background: linear-gradient(150deg, #6e2475, #571a58); }
      .btn-primary:active { transform: scale(.98); }
      .btn-ghost { background: var(--surface-2); color: var(--fg); border-color: var(--line); }
      .btn-ghost:hover { background: var(--surface-hover); }

      .back { display: inline-flex; align-items: center; gap: 6px; color: var(--muted); font-size: .88rem; margin-bottom: 14px; }
      .back:hover { color: var(--accent); }

      .muted { color: var(--muted); }
      .faint { color: var(--faint); }

      /* 본문 테이블 */
      table.data { width: 100%; border-collapse: collapse; font-size: .9rem; }
      table.data thead th { text-align: left; color: var(--muted); font-weight: 600; font-size: .78rem; letter-spacing: .02em; text-transform: uppercase; padding: 10px 12px; border-bottom: 1px solid var(--line); }
      table.data tbody td { padding: 12px; border-bottom: 1px solid var(--line-soft); vertical-align: top; }
      table.data tbody tr { transition: background .12s ease; }
      table.data tbody tr:hover { background: var(--surface-2); }
      table.data tbody tr:last-child td { border-bottom: none; }

      /* 리스트 */
      ul.clean { list-style: none; padding: 0; margin: 0; }
      ul.clean li { border-bottom: 1px solid var(--line-soft); }
      ul.clean li:last-child { border-bottom: none; }
      ul.clean li a.row { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 13px 4px; transition: padding .15s ease, color .15s ease; }
      ul.clean li a.row:hover { padding-left: 12px; color: var(--accent); }

      /* 푸터 */
      footer.site { max-width: var(--maxw); margin: 0 auto; padding: 28px 24px 40px; border-top: 1px solid var(--line-soft); color: var(--faint); font-size: .82rem; display: flex; flex-wrap: wrap; gap: 8px 18px; align-items: center; }

      /* 진입 페이드 (MOTION 3) */
      @media (prefers-reduced-motion: no-preference) {
        main > * { animation: rise .5s cubic-bezier(.16,1,.3,1) both; }
        @keyframes rise { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }
      }

      /* 모바일 */
      @media (max-width: 768px) {
        header.site { gap: 14px; padding: 0 16px; }
        .brand small { display: none; }
        main { padding: 22px 16px 56px; }
      }
    </style>
  </head>
  <body>
    <header class="site">
      <a href="/" class="brand">
        <span class="mark" aria-hidden="true"></span>
        발주공고 <small>MDB Agri Tenders</small>
      </a>
      <nav class="site">
        <a href="/" aria-current={isActive("/") ? "page" : undefined}>대시보드</a>
        <a href="/notices" aria-current={isActive("/notices") ? "page" : undefined}>공고 목록</a>
      </nav>
    </header>
    <main><slot /></main>
    <footer class="site">
      <span>WB · ADB · AIIB · AfDB · KOICA · EDCF · JICA 농업분야 발주공고</span>
    </footer>
  </body>
</html>
