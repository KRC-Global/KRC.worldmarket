---
interface Props { title?: string }
const { title = "MDB 농업 발주공고" } = Astro.props;
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <title>{title}</title>
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <style is:global>
      /* Pretendard (Pretendard GOV 미설치 시 폴백) — KRDS 표준 서체 */
      @import url("https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.css");

      /* ── KRDS(대한민국 정부 디자인시스템) 토큰을 네이티브 CSS로 구현 ── */
      :root {
        color-scheme: light;

        /* Primary (정부 블루) */
        --kb-5: #ecf2fe;  --kb-10: #d8e5fd; --kb-40: #4c87f6;
        --kb-50: #256ef4; --kb-60: #0b50d0; --kb-70: #083891;
        /* Secondary (네이비) */
        --kn-5: #eef2f7;  --kn-50: #346fb2; --kn-70: #063a74;
        /* Grayscale */
        --g0: #ffffff;  --g5: #f4f5f6;  --g10: #e6e8ea; --g20: #cdd1d5;
        --g30: #b1b8be; --g40: #8a949e; --g50: #6d7882; --g60: #58616a;
        --g70: #464c53; --g80: #33363d; --g90: #1e2124;
        /* 시맨틱 */
        --success: #228738; --warning-bg: #ffb114; --warning-tx: #9e6a00;
        --danger: #de3412;  --info: #0b78cb;  --point: #d63d4a;

        /* 의미 토큰 */
        --bg: var(--g0);
        --bg-alt: var(--g5);
        --surface: var(--g0);
        --line: var(--g10);
        --line-strong: var(--g20);
        --fg: var(--g90);
        --muted: var(--g50);
        --accent: var(--kb-50);
        --accent-strong: var(--kb-60);
        --on-accent: #ffffff;

        /* 형상 — KRDS: 버튼·입력 6 / 카드·패널 8 / 배지 4 */
        --r-btn: 6px;  --r-card: 8px;  --r-badge: 4px;
        --focus: 0 0 0 4px rgb(37 110 244 / .35);
        --shadow: 0 1px 2px rgb(30 33 36 / .06), 0 4px 16px rgb(30 33 36 / .06);
        --maxw: 1200px;
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }

      body {
        margin: 0; min-height: 100dvh;
        background: var(--bg); color: var(--fg);
        font-family: "Pretendard GOV", "Pretendard Variable", Pretendard,
          -apple-system, BlinkMacSystemFont, "Apple SD Gothic Neo",
          "Noto Sans KR", system-ui, sans-serif;
        font-size: 17px; line-height: 1.5;     /* KRDS Body medium 기본 */
        font-feature-settings: "tnum" 1;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      :focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; border-radius: 2px; }

      h1 { font-size: clamp(1.5rem, 1.2rem + 1.4vw, 2rem); font-weight: 700; letter-spacing: -.02em; line-height: 1.3; margin: 0 0 .3em; color: var(--g90); }
      h2 { font-size: 1.375rem; font-weight: 700; letter-spacing: -.01em; margin: 0 0 .4em; }
      h3 { font-size: 1.0625rem; font-weight: 700; margin: 0 0 .7em; color: var(--g80); }
      p { margin: .4em 0; }

      /* ── 정부 신뢰 마스트헤드(상단 띠) ── */
      .gov-bar { background: var(--g5); border-bottom: 1px solid var(--line); }
      .gov-bar .inner { max-width: var(--maxw); margin: 0 auto; padding: 6px 24px; font-size: .8125rem; color: var(--muted); display: flex; align-items: center; gap: 7px; }
      .gov-bar .tae { width: 13px; height: 13px; border-radius: 50%; flex: none;
        background: conic-gradient(from 90deg, var(--kb-50) 0 50%, var(--point) 50% 100%); }

      /* ── 헤더 ── */
      header.site {
        position: sticky; top: 0; z-index: 50; background: var(--g0);
        border-bottom: 1px solid var(--line-strong);
        height: 68px; display: flex; align-items: center; gap: 28px; padding: 0 24px;
      }
      .brand { display: inline-flex; align-items: center; gap: 11px; font-weight: 700; letter-spacing: -.02em; font-size: 1.0625rem; color: var(--g90); }
      .brand:hover { text-decoration: none; }
      .brand .mark { width: 30px; height: 30px; border-radius: 7px; flex: none; background: var(--kb-50); position: relative; }
      .brand .mark::before { content: ""; position: absolute; inset: 0; margin: auto; top: 7px; width: 7px; height: 7px; border-radius: 50%; background: #fff; }
      .brand .mark::after { content: ""; position: absolute; left: 50%; transform: translateX(-50%); bottom: 6px; width: 2.5px; height: 9px; border-radius: 2px; background: rgb(255 255 255 / .9); }
      .brand small { color: var(--muted); font-weight: 500; font-size: .75rem; }

      nav.site { display: flex; gap: 2px; align-items: center; }
      nav.site a { color: var(--g70); font-size: .9375rem; font-weight: 600; padding: 8px 14px; border-radius: var(--r-btn); transition: background .12s ease, color .12s ease; }
      nav.site a:hover { color: var(--g90); background: var(--g5); text-decoration: none; }
      nav.site a[aria-current="page"] { color: var(--accent-strong); background: var(--kb-5); }

      main { max-width: var(--maxw); margin: 0 auto; padding: 32px 24px 72px; }

      /* ── 카드 / 그리드 ── */
      .card { background: var(--surface); border: 1px solid var(--line-strong); border-radius: var(--r-card); padding: 20px; }
      .card.pad-lg { padding: 24px; }
      .grid { display: grid; gap: 16px; }

      /* 통계 카드 */
      .stat { background: var(--g0); border: 1px solid var(--line-strong); border-radius: var(--r-card); padding: 20px 22px; position: relative; overflow: hidden; transition: border-color .15s ease, box-shadow .15s ease; }
      .stat::before { content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: var(--accent); }
      .stat:hover { border-color: var(--kb-40); box-shadow: var(--shadow); }
      .stat .k { color: var(--muted); font-size: .875rem; font-weight: 600; }
      .stat .v { font-size: 2rem; font-weight: 700; letter-spacing: -.02em; font-variant-numeric: tabular-nums; margin-top: 4px; color: var(--g90); }

      /* 배지 */
      .badge { display: inline-flex; align-items: center; gap: 6px; padding: 3px 9px; border-radius: var(--r-badge);
        font-size: .8125rem; font-weight: 600; background: var(--kb-5); color: var(--accent-strong); border: 1px solid var(--kb-10); white-space: nowrap; }
      .badge .dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }

      /* 폼 컨트롤 — KRDS medium(48px) */
      .field { height: 48px; background: var(--g0); color: var(--g90); border: 1px solid var(--g60); border-radius: var(--r-btn); padding: 0 14px; font: inherit; font-size: .9375rem; transition: border-color .12s ease, box-shadow .12s ease; }
      .field::placeholder { color: var(--g50); }
      .field:focus { outline: none; border-color: var(--accent); box-shadow: var(--focus); }

      /* 버튼 */
      .btn { display: inline-flex; align-items: center; gap: 7px; height: 48px; padding: 0 20px; border-radius: var(--r-btn); font: inherit; font-size: .9375rem; font-weight: 700; cursor: pointer; border: 1px solid transparent; transition: background .12s ease, border-color .12s ease; }
      .btn-primary { background: var(--accent); color: var(--on-accent); }
      .btn-primary:hover { background: var(--accent-strong); text-decoration: none; }
      .btn-primary:active { background: var(--kb-70); }
      .btn-ghost { background: var(--g0); color: var(--g80); border-color: var(--g60); }
      .btn-ghost:hover { background: var(--g5); text-decoration: none; }

      .back { display: inline-flex; align-items: center; gap: 6px; color: var(--muted); font-size: .9375rem; margin-bottom: 14px; }
      .back:hover { color: var(--accent); }
      .muted { color: var(--muted); }
      .faint { color: var(--g40); }

      /* 본문 테이블 */
      table.data { width: 100%; border-collapse: collapse; font-size: .9375rem; }
      table.data thead th { text-align: left; color: var(--g70); font-weight: 700; font-size: .8125rem; padding: 12px 14px; background: var(--g5); border-bottom: 1px solid var(--line-strong); }
      table.data tbody td { padding: 14px; border-bottom: 1px solid var(--line); vertical-align: top; }
      table.data tbody tr { transition: background .1s ease; }
      table.data tbody tr:hover { background: var(--kb-5); }
      table.data tbody tr:last-child td { border-bottom: none; }

      /* 리스트 */
      ul.clean { list-style: none; padding: 0; margin: 0; }
      ul.clean li { border-bottom: 1px solid var(--line); }
      ul.clean li:last-child { border-bottom: none; }
      ul.clean li a.row { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 14px 4px; color: var(--g90); transition: padding .12s ease; }
      ul.clean li a.row:hover { padding-left: 10px; color: var(--accent); text-decoration: none; }

      /* 푸터 */
      footer.site { border-top: 1px solid var(--line-strong); background: var(--g5); }
      footer.site .inner { max-width: var(--maxw); margin: 0 auto; padding: 28px 24px 40px; color: var(--muted); font-size: .875rem; }

      @media (max-width: 768px) {
        .gov-bar .inner, header.site { padding-left: 16px; padding-right: 16px; }
        header.site { gap: 14px; }
        .brand small { display: none; }
        main { padding: 22px 16px 56px; }
        body { font-size: 16px; }
      }
    </style>
  </head>
  <body>
    <div class="gov-bar"><div class="inner"><span class="tae" aria-hidden="true"></span>대한민국 농어촌공사 · MDB 농업분야 발주공고 정보 서비스</div></div>
    <header class="site">
      <a href="/" class="brand">
        <span class="mark" aria-hidden="true"></span>
        발주공고 <small>MDB 농업 발주공고</small>
      </a>
      <nav class="site">
        <a href="/" aria-current={isActive("/") ? "page" : undefined}>대시보드</a>
        <a href="/notices" aria-current={isActive("/notices") ? "page" : undefined}>공고 목록</a>
      </nav>
    </header>
    <main><slot /></main>
    <footer class="site"><div class="inner">
      WB · ADB · AIIB · AfDB · IsDB · KOICA · EDCF 의 농업분야 발주공고를 수집·분석해 제공합니다.
    </div></footer>
  </body>
</html>
