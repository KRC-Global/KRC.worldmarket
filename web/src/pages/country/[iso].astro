---
import Layout from "../../layouts/Layout.astro";
import { supabase } from "../../lib/supabase";
import { MDB_LABELS, type Notice } from "../../types";

const { iso } = Astro.params;
const { data } = await supabase
  .from("notices").select("*").eq("country_iso", iso)
  .order("published_at", { ascending: false }).limit(200);
const rows = (data as Notice[]) ?? [];
const country = rows[0]?.country ?? iso;
---

<Layout title={`${country} 현황`}>
  <a class="back" href="/">← 대시보드</a>
  <span class="badge"><span class="dot"></span>{country}</span>
  <h1 style="margin-top:10px">{country} 발주공고 <span class="muted" style="font-weight:600">({rows.length})</span></h1>
  <div class="card" style="margin-top:18px;padding:6px 18px">
    <ul class="clean">
      {rows.map((r) => (
        <li><a class="row" href={`/notices/${r.id}`}><span>{r.title}</span><span class="badge"><span class="dot"></span>{MDB_LABELS[r.source]}</span></a></li>
      ))}
    </ul>
  </div>
</Layout>
