---
import Layout from "../../layouts/Layout.astro";
import { supabase } from "../../lib/supabase";
import { MDB_LABELS, type MdbSource, type Notice } from "../../types";

const { mdb } = Astro.params;
const label = MDB_LABELS[mdb as MdbSource] ?? mdb;
const { data } = await supabase
  .from("notices").select("*").eq("source", mdb)
  .order("published_at", { ascending: false }).limit(200);
const rows = (data as Notice[]) ?? [];
---

<Layout title={`${label} 현황`}>
  <a class="back" href="/">← 대시보드</a>
  <span class="badge"><span class="dot"></span>{label}</span>
  <h1 style="margin-top:10px">{label} 발주공고 <span class="muted" style="font-weight:600">({rows.length})</span></h1>
  <div class="card" style="margin-top:18px;padding:6px 18px">
    <ul class="clean">
      {rows.map((r) => (
        <li><a class="row" href={`/notices/${r.id}`}><span>{r.title}</span><span class="muted">{r.country ?? "-"}</span></a></li>
      ))}
    </ul>
  </div>
</Layout>
